---
import BaseLayout from "../layouts/BaseLayout.astro";
import ContactSurface from "../components/ContactSurface.astro";
import { SITE } from "../config/site";
import { TOOLS } from "../lib/tools";
import AdSlot from "../components/AdSlot.astro";

const title = "CloudCostKit | Cloud cost calculators and pricing guides";
const description =
  "Cloud cost calculators and pricing guides for AWS, Azure, and GCP. Estimate egress, logs, storage, compute, and managed-service bills with transparent assumptions, validation checklists, and calculator-first workflows.";

const featuredSlugs = [
  "cdn-cost-calculator",
  "kubernetes-cost-calculator",
  "storage-pricing-calculator",
  "storage-replication-cost-calculator",
  "data-egress-cost-calculator",
  "log-ingestion-cost-calculator",
];

const featured = TOOLS.filter((t) => featuredSlugs.includes(t.slug));
const slots = SITE.adsenseSlots;

const demandPaths = [
  {
    href: "/calculators/cdn-cost-calculator/",
    title: "CDN cost and pricing",
    desc: "High search demand topic: compare bandwidth, requests, and origin-side spillover.",
  },
  {
    href: "/calculators/ec2-cost-calculator/",
    title: "EC2 monthly cost",
    desc: "Turn instance-hours and blended hourly rates into a fast baseline vs peak estimate.",
  },
  {
    href: "/calculators/data-egress-cost-calculator/",
    title: "Egress and transfer charges",
    desc: "Separate internet, cross-region, cross-AZ, and origin-to-CDN before you trust the number.",
  },
  {
    href: "/guides/gcp-cloud-run-pricing/",
    title: "Cloud Run pricing inputs",
    desc: "Requests, CPU, memory, egress, and logs in one calculator-ready checklist.",
  },
];
---
<BaseLayout title={title} description={description} canonicalPath="/">
  <section class="card hero">
    <span class="pill">Cloud / FinOps / DevOps</span>
    <h1>Cloud cost & capacity calculators</h1>
    <p>
      Estimate egress, logs, storage, EC2, CDN, and Kubernetes capacity with clear assumptions. Use the same workload
      profile to compare scenarios, validate pricing, and plan budgets faster.
    </p>
    <div class="hero-actions">
      <a class="btn btn-primary" href="/calculators/">Browse tools</a>
      <a class="btn" href="/guides/">Start with guides</a>
      <a class="btn" href="/calculators/data-egress-cost-calculator/">Estimate egress</a>
      <a class="btn" href="/calculators/cdn-cost-calculator/">Compare CDN cost</a>
    </div>
  </section>

  <section class="card section prose" style="margin-top:18px">
    <h2 style="margin-top:0">Review how this site works</h2>
    <p class="muted" style="margin:10px 0 0">
      CloudCostKit is designed to be reviewable, not mysterious. Use the trust path below to see what the site is for,
      how pages are maintained, how estimates are validated, and where to report a correction.
    </p>
    <p class="muted" style="margin:10px 0 0">
      The site is maintained by the CloudCostKit Editorial Team, and this path explains how pages are reviewed, challenged, and corrected before they keep strong placement.
    </p>
    <div class="grid" style="margin-top:12px">
      <a class="card2 tool col-6" href="/about/">
        <div class="tool-title">About the site</div>
        <div class="tool-desc">Who the site serves, what decisions it supports, and what it does not replace.</div>
      </a>
      <a class="card2 tool col-6" href="/editorial-policy/">
        <div class="tool-title">Editorial standards</div>
        <div class="tool-desc">How topics qualify for publication, review, consolidation, or rewrite.</div>
      </a>
      <a class="card2 tool col-6" href="/methodology/">
        <div class="tool-title">Methodology</div>
        <div class="tool-desc">How calculator and guide workflows are built, validated, and challenged.</div>
      </a>
      <a class="card2 tool col-6" href="/contact/">
        <div class="tool-title">Report a correction</div>
        <div class="tool-desc">Send a bug report, estimate mismatch, or unclear boundary with the details needed to review it.</div>
      </a>
    </div>
  </section>

  <section class="card section prose" style="margin-top:18px">
    <h2 style="margin-top:0">Best places to start right now</h2>
    <p class="muted" style="margin:10px 0 0">
      These are the workflows already showing live search demand, so they are strong entry points whether you are
      budgeting, comparing providers, or investigating a spike.
    </p>
    <div class="grid" style="margin-top:12px">
      {demandPaths.map((item) => (
        <a class="card2 tool col-6" href={item.href}>
          <div class="tool-title">{item.title}</div>
          <div class="tool-desc">{item.desc}</div>
        </a>
      ))}
    </div>
  </section>

  <section class="card section">
    <h2 style="margin:0 0 12px">Featured tools</h2>
    <div class="grid">
      {featured.map((t) => (
        <a class="card2 tool col-6" href={`/calculators/${t.slug}/`}>
          <div class="tool-title">{t.title}</div>
          <div class="tool-desc">{t.description}</div>
          <div class="muted" style="font-size:12px; margin-top:4px">{t.category}</div>
        </a>
      ))}
    </div>
  </section>

  <section class="card section" style="margin-top:18px">
    <h2 style="margin:0 0 12px">Guides</h2>
    <div class="grid">
      <a class="card2 tool col-6" href="/guides/egress-costs/">
        <div class="tool-title">Understanding egress costs</div>
        <div class="tool-desc">How to estimate bandwidth and avoid billing surprises.</div>
      </a>
      <a class="card2 tool col-6" href="/guides/log-costs/">
        <div class="tool-title">Estimating log costs</div>
        <div class="tool-desc">Ingestion vs retention, steady state, and knobs that matter.</div>
      </a>
      <a class="card2 tool col-6" href="/guides/cdn-costs/">
        <div class="tool-title">CDN cost breakdown</div>
        <div class="tool-desc">Bandwidth, requests, cache fill, and origin egress explained.</div>
      </a>
      <a class="card2 tool col-6" href="/guides/kubernetes-costs/">
        <div class="tool-title">Kubernetes cost modeling guide</div>
        <div class="tool-desc">What to include beyond nodes: storage, egress, load balancers, and observability.</div>
      </a>
      <a class="card2 tool col-6" href="/guides/azure-event-hubs-pricing/">
        <div class="tool-title">Azure Event Hubs pricing</div>
        <div class="tool-desc">Estimate throughput, retention, replay exposure, and downstream consumer-side cost amplification.</div>
      </a>
      <a class="card2 tool col-6" href="/guides/azure-load-balancer-pricing/">
        <div class="tool-title">Azure Load Balancer pricing</div>
        <div class="tool-desc">Model hours, data processed, and internet egress without blending L4 traffic and transfer costs.</div>
      </a>
      <a class="card2 tool col-6" href="/guides/azure-container-registry-pricing/">
        <div class="tool-title">Azure Container Registry pricing</div>
        <div class="tool-desc">Estimate storage, pull-heavy traffic, and geo-replication before registry usage spikes.</div>
      </a>
      <a class="card2 tool col-6" href="/guides/gcp-cloud-run-pricing/">
        <div class="tool-title">GCP Cloud Run pricing</div>
        <div class="tool-desc">Model requests, CPU, memory, cold starts, and egress with deployment-ready assumptions.</div>
      </a>
    </div>
  </section>

  <section class="grid" style="margin-top:18px">
    <div class="card section prose col-6">
      <h2 style="margin-top:0">What these tools are for</h2>
      <ul class="muted" style="margin:10px 0 0; padding-left:18px">
        <li>Budgeting: get quick back-of-the-napkin estimates.</li>
        <li>Comparisons: evaluate regions, tiers, and workload shapes.</li>
        <li>Right-sizing: translate app requirements into capacity numbers.</li>
      </ul>
    </div>
    <div class="card section prose col-6">
      <h2 style="margin-top:0">What to verify</h2>
      <p class="muted" style="margin:10px 0 0">
        Provider pricing varies by region, tiers, free allowances, request classes, and rounding rules. Always confirm
        assumptions in official docs before committing spend.
      </p>
      <ContactSurface email={SITE.email} label="Questions and feedback" variant="compact" />
    </div>
  </section>

  <section class="card section prose" style="margin-top:18px">
    <h2 style="margin-top:0">Pick a starting path (by your cost problem)</h2>
    <div class="grid" style="margin-top:10px">
      <a class="card2 tool col-6" href="/calculators/data-egress-cost-calculator/">
        <div class="tool-title">Network bill spikes</div>
        <div class="tool-desc">Start with egress boundary split: internet, cross-region, cross-AZ, and origin-to-CDN.</div>
      </a>
      <a class="card2 tool col-6" href="/calculators/log-cost-calculator/">
        <div class="tool-title">Observability cost growth</div>
        <div class="tool-desc">Model ingestion, retention, and scan/query separately before tuning dashboards.</div>
      </a>
      <a class="card2 tool col-6" href="/calculators/storage-pricing-calculator/">
        <div class="tool-title">Storage keeps growing</div>
        <div class="tool-desc">Use GB-month growth and lifecycle scenarios instead of month-end snapshots.</div>
      </a>
      <a class="card2 tool col-6" href="/calculators/kubernetes-cost-calculator/">
        <div class="tool-title">Kubernetes budget drift</div>
        <div class="tool-desc">Start from requests and node sizing, then add networking, logs, and load balancers.</div>
      </a>
    </div>
  </section>

  <section class="card section prose" style="margin-top:18px">
    <h2 style="margin-top:0">What makes these estimates more reliable</h2>
    <ul class="muted" style="margin:10px 0 0; padding-left:18px">
      <li><strong>Driver-first modeling</strong>: requests, GB, GB-month, and hours before pricing detail.</li>
      <li><strong>Boundary-first networking</strong>: we split traffic paths to avoid hidden transfer mistakes.</li>
      <li><strong>Baseline + peak</strong>: each core workflow encourages incident and launch scenarios.</li>
      <li><strong>Calculator + guide pairing</strong>: each estimate has a matching explanation page for validation.</li>
      <li><strong>No black-box formulas</strong>: assumptions are explicit so teams can challenge and update them.</li>
      <li><strong>Visible review path</strong>: strong pages keep prominent routing only while their role, boundaries, and correction path remain defensible.</li>
    </ul>
  </section>

  <section class="section">
    <AdSlot slot={slots.homeMid} minHeight={280} />
  </section>
</BaseLayout>


