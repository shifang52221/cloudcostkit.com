  <div class="btn-row">
    <a class="btn" href="/calculators/aws-ssm-parameter-store-cost-calculator/">Parameter Store cost</a>
    <a class="btn" href="/guides/aws-ssm-parameter-store-estimate-api-calls/">Estimate API calls</a>
    <a class="btn" href="/guides/aws-ssm-parameter-store-cost-optimization/">Reduce costs</a>
    <a class="btn" href="/guides/request-based-pricing/">Request-based pricing</a>
    <a class="btn" href="/guides/cloud-cost-estimation-checklist/">Cost checklist</a>
  </div>

