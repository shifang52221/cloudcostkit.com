---
import GuideLayout from "../../layouts/GuideLayout.astro";
import { GUIDES } from "../../lib/guides.generated";
import { withTrailingSlash } from "../../lib/url";

const title = "Request Pricing Hub: calculators, guides, and next steps";
const description =
  "Use this request pricing hub to route into request math, retries, payload transfer, and adjacent cost checks when you need the right guide or calculator without mixing request scope across services.";

const faqs = [
  {
    q: "What services are request-priced?",
    a: "Many edge and API products: API gateways, CDNs, WAFs, serverless invocations, and some messaging services. The unit varies by provider (per 10k, per 1M, per 100k).",
  },
  {
    q: "How do I estimate quickly?",
    a: "Convert RPS to monthly requests, then model retries separately. For fan-out systems (messaging), estimate deliveries per message and multiply.",
  },
  {
    q: "What breaks estimates?",
    a: "Retry storms, bot traffic, and unit mistakes (per 10k vs per 1M). Also, average RPS can hide spikes that dominate cost on bursty workloads.",
  },
];

const requestGuides = GUIDES.filter((g) => (g.topics || []).includes("requests") && g.canonicalPath !== "/guides/requests-costs")
  .slice()
  .sort((a, b) => a.title.localeCompare(b.title))
  .slice(0, 18);
---
<GuideLayout
  title={title}
  description={description}
  canonicalPath="/guides/requests-costs"
  lastUpdated="2026-03-27"
  faqs={faqs}
  robots="noindex,follow"
>
  <p class="muted">
    This is the request boundary page. Retries, bots, cache misses, and other traffic amplifiers belong in this model
    before you price the bill.
  </p>
  <p class="muted">
    Use the calculators only after the boundary is defined so every estimate inherits the same definition of billable
    requests.
  </p>

  <div class="btn-row">
    <a class="btn" href="/guides/request-based-pricing/">Main guide: request-based pricing</a>
    <a class="btn" href="/calculators/rps-to-monthly-requests-calculator/">RPS to monthly requests</a>
    <a class="btn" href="/calculators/api-request-cost-calculator/">Request cost calculator</a>
  </div>

  <h2>Choose your next step</h2>
  <ul>
    <li><strong>Need the full request workflow?</strong> Start with <a href="/guides/request-based-pricing/">request-based pricing explained</a>.</li>
    <li><strong>Need quick monthly volume?</strong> Use <a href="/calculators/rps-to-monthly-requests-calculator/">RPS to monthly requests</a>.</li>
    <li><strong>Need direct request cost math?</strong> Use <a href="/calculators/api-request-cost-calculator/">request cost calculator</a>.</li>
    <li><strong>Need event and delivery budgeting?</strong> Go to <a href="/guides/messaging-costs/">messaging costs</a>.</li>
  </ul>

  <h2>Use this hub when you only need routing</h2>
  <ul>
    <li>Use this page when you already know the topic and just need the shortest path to the stronger guide or tool.</li>
    <li>Do not use this page as your main explainer if you still need unit mapping, traffic-shape modeling, or validation steps.</li>
    <li>That full job belongs to <a href="/guides/request-based-pricing/">request-based pricing explained</a>.</li>
  </ul>

  <h2>The biggest mistake on this page is reading a hub like a full guide</h2>
  <p>
    This page exists to reduce confusion, not to reteach the whole request-pricing workflow. If you still need a
    complete estimate method, jump to the main request guide instead of trying to piece the workflow together from a hub.
  </p>

  <h2>Fast exits by problem type</h2>
  <ul>
    <li><strong>Retries and incidents</strong>: <a href="/guides/request-based-pricing/">request-based pricing explained</a></li>
    <li><strong>Payload and transfer</strong>: <a href="/calculators/api-response-size-transfer-calculator/">response size transfer</a></li>
    <li><strong>Security spike context</strong>: <a href="/guides/security-costs/">security costs</a></li>
    <li><strong>Messaging fan-out and deliveries</strong>: <a href="/guides/messaging-costs/">messaging costs</a></li>
  </ul>
  <p class="muted">
    For the full workflow, continue with <a href="/guides/request-based-pricing/">request-based pricing explained</a>.
    This page should stay a lightweight navigation stop.
  </p>

  <h2>Related tools</h2>
  <div class="btn-row">
    <a class="btn" href="/calculators/api-request-cost-calculator/">Request cost</a>
    <a class="btn" href="/calculators/cdn-request-cost-calculator/">CDN request cost</a>
    <a class="btn" href="/calculators/aws-waf-cost-calculator/">WAF cost</a>
    <a class="btn" href="/guides/messaging-costs/">Messaging costs</a>
  </div>

  {requestGuides.length ? (
    <>
      <h2>More request pricing guides</h2>
      <div class="grid">
        {requestGuides.map((g) => (
          <a class="card2 tool col-6" href={withTrailingSlash(g.canonicalPath)}>
            <div class="tool-title">{g.title}</div>
            <div class="tool-desc">{g.description}</div>
          </a>
        ))}
      </div>
    </>
  ) : null}
</GuideLayout>

