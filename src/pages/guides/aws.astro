---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { SITE } from "../../config/site";
import AdSlot from "../../components/AdSlot.astro";
import { GUIDES } from "../../lib/guides.generated";
import type { GuideLink } from "../../lib/guides.generated";
import { withTrailingSlash } from "../../lib/url";

const title = `AWS cost guides | ${SITE.name}`;
const description =
  "AWS cost guide hub for routing into the right estimating workflow across networking, runtime, storage, observability, messaging, and service-specific budgeting traps before you choose a deeper page.";
const slots = SITE.adsenseSlots;

type GuideGroup = {
  title: string;
  description: string;
  items: GuideLink[];
};

const awsGuides = GUIDES.filter((g) => g.category === "AWS");

function hasAnyTopic(guide: GuideLink, topics: string[]) {
  return topics.some((topic) => guide.topics?.includes(topic));
}

function slugMatches(guide: GuideLink, parts: string[]) {
  return parts.some((part) => guide.slug.includes(part));
}

function sortGuides(guides: GuideLink[]) {
  return guides.slice().sort((a, b) => a.title.localeCompare(b.title));
}

const routeCards = [
  {
    title: "Transfer-heavy bill",
    description: "Start here when NAT, CDN origin, PrivateLink, cross-AZ, or Route 53 style traffic is the real source of uncertainty.",
    guideHref: "/guides/aws-network-costs/",
    guideLabel: "Network cost hub",
    toolHref: "/calculators/data-egress-cost-calculator/",
    toolLabel: "Egress calculator",
  },
  {
    title: "Runtime-heavy bill",
    description: "Start here when the hard question is EC2 vs Fargate vs Lambda vs ECS/EKS, not just the hourly rate on one service page.",
    guideHref: "/guides/aws-fargate-pricing/",
    guideLabel: "Runtime guide",
    toolHref: "/calculators/aws-fargate-vs-ec2-cost-calculator/",
    toolLabel: "Runtime compare",
  },
  {
    title: "Storage-growth-heavy bill",
    description: "Start here when storage, backups, snapshots, retention, or replication is compounding quietly month over month.",
    guideHref: "/guides/aws-rds-pricing/",
    guideLabel: "Storage and data guide",
    toolHref: "/calculators/database-storage-growth-cost-calculator/",
    toolLabel: "Growth calculator",
  },
  {
    title: "Observability-heavy bill",
    description: "Start here when Logs, Insights, Metrics, Alarms, or CloudTrail spend is growing faster than the workload itself.",
    guideHref: "/guides/aws-cloudwatch-logs-pricing/",
    guideLabel: "Observability guide",
    toolHref: "/calculators/log-cost-calculator/",
    toolLabel: "Log calculator",
  },
  {
    title: "Request-heavy bill",
    description: "Start here when retries, polling, fan-out, API calls, or request-unit math is the part most likely to make the estimate wrong.",
    guideHref: "/guides/aws-sqs-pricing/",
    guideLabel: "Request-driven guide",
    toolHref: "/calculators/api-request-cost-calculator/",
    toolLabel: "Request calculator",
  },
];

const awsGuideGroups: GuideGroup[] = [
  {
    title: "Networking and delivery",
    description: "Use these when transfer boundaries, edge services, endpoint hours, or traffic shape are the main source of cost risk.",
    items: sortGuides(
      awsGuides.filter(
        (guide) =>
          hasAnyTopic(guide, ["cdn", "egress", "load-balancing"]) ||
          slugMatches(guide, ["route-53", "nat", "vpc", "privatelink", "cloudfront", "alb", "api-gateway"]),
      ),
    ),
  },
  {
    title: "Runtime and platform",
    description: "Use these when the estimate depends on runtime choice, idle capacity, autoscaling behavior, or cluster overhead.",
    items: sortGuides(
      awsGuides.filter(
        (guide) =>
          hasAnyTopic(guide, ["compute", "kubernetes", "serverless"]) ||
          slugMatches(guide, ["ec2", "lambda", "fargate", "ecs", "eks"]),
      ),
    ),
  },
  {
    title: "Storage and data",
    description: "Use these when stored GB-month, retention, backups, snapshots, replication, or database growth are likely to dominate.",
    items: sortGuides(
      awsGuides.filter(
        (guide) =>
          hasAnyTopic(guide, ["backup", "database", "storage"]) ||
          slugMatches(guide, ["s3", "rds", "aurora", "ebs", "dynamodb", "ecr", "glacier"]),
      ),
    ),
  },
  {
    title: "Observability and operations",
    description: "Use these when logs, metrics, alarms, dashboards, or audit event volume are drifting faster than expected.",
    items: sortGuides(
      awsGuides.filter(
        (guide) =>
          hasAnyTopic(guide, ["logging", "metrics"]) ||
          slugMatches(guide, ["cloudwatch", "cloudtrail", "logs", "metrics", "alarm"]),
      ),
    ),
  },
  {
    title: "Messaging, security, and request multipliers",
    description: "Use these when deliveries, polling, retries, crypto calls, WAF traffic, or request-unit amplification is the real problem.",
    items: sortGuides(
      awsGuides.filter(
        (guide) =>
          hasAnyTopic(guide, ["messaging", "requests", "security"]) ||
          slugMatches(guide, ["sqs", "sns", "ses", "kms", "secrets", "ssm", "waf"]),
      ),
    ),
  },
].filter((group) => group.items.length);
---
<BaseLayout title={title} description={description} canonicalPath="/guides/aws" robots="noindex,follow">
  <section class="card hero">
    <h1>AWS cost guides</h1>
    <p>This page is an AWS routing layer: use it to choose the next estimating job, not to replace the deeper service guide you actually need.</p>
    <div class="btn-row" style="margin-top:12px">
      <a class="btn btn-primary" href="/calculators/aws/">AWS calculators</a>
      <a class="btn" href="/guides/cloud-cost-estimation-checklist/">Estimation checklist</a>
      <a class="btn" href="/methodology/">Methodology</a>
      <a class="btn" href="/editorial-policy/">Editorial policy</a>
    </div>
  </section>

  <section class="grid" style="margin-top:18px">
    <section class="card section prose col-6">
      <h2 style="margin-top:0">What this hub is for</h2>
      <p class="muted" style="margin:0">
        Start here when you already know the problem is AWS-specific, but you do not yet know which billing path is the
        one that needs the next review.
      </p>
      <ul class="muted" style="margin:12px 0 0; padding-left:18px">
        <li>Use it to pick the next guide by cost shape, not by keyword similarity.</li>
        <li>Use the deeper service guide once the main line item is clear.</li>
        <li>Switch to the calculator when you have measurable drivers and need a first-pass number.</li>
      </ul>
    </section>
    <section class="card section prose col-6">
      <h2 style="margin-top:0">What usually breaks AWS estimates</h2>
      <p class="muted" style="margin:0">
        AWS estimates usually fail when traffic boundaries, retries, observability growth, or backup/replication
        effects are added after the service price instead of before it.
      </p>
      <ul class="muted" style="margin:12px 0 0; padding-left:18px">
        <li>Transfer is mixed together before internet, cross-AZ, cross-region, and endpoint paths are separated.</li>
        <li>Runtime comparisons ignore the line items around the runtime: logs, load balancers, storage, and idle waste.</li>
        <li>Storage estimates use end-of-month size and skip churn, retention, or replica copies.</li>
        <li>Request-heavy systems hide retries, polling, fan-out, and incident amplification inside one blended average.</li>
      </ul>
    </section>
  </section>

  <section class="card section prose" style="margin-top:18px">
    <h2 style="margin-top:0">Start with the bill shape that is already causing uncertainty</h2>
    <p class="muted" style="margin:0">Start with the bill shape that is already causing uncertainty: transfer-heavy, runtime-heavy, storage-growth-heavy, observability-heavy, or request-heavy.</p>
    <div class="guide-cluster-grid" style="margin-top:14px">
      {routeCards.map((card) => (
        <div class="card2 guide-cluster-card">
          <div class="guide-cluster-copy">
            <div class="tool-title">{card.title}</div>
            <div class="tool-desc">{card.description}</div>
          </div>
          <div class="btn-row guide-cluster-actions" style="margin-top:12px">
            <a class="btn" href={card.guideHref}>{card.guideLabel}</a>
            <a class="btn" href={card.toolHref}>{card.toolLabel}</a>
          </div>
        </div>
      ))}
    </div>
  </section>

  {awsGuideGroups.map((group) => (
    <section class="card section" style="margin-top:18px">
      <div class="prose">
        <h2 style="margin-top:0">{group.title}</h2>
        <p class="muted" style="margin:0">{group.description}</p>
      </div>
      <div class="grid" style="margin-top:14px">
        {group.items.map((guide) => (
          <a class="card2 tool col-6" href={withTrailingSlash(guide.canonicalPath)}>
            <div class="tool-title">{guide.title}</div>
            <div class="tool-desc">{guide.description}</div>
          </a>
        ))}
      </div>
    </section>
  ))}

  <section class="section">
    <AdSlot slot={slots.guidesMid} minHeight={280} />
  </section>

  <section class="card section prose" style="margin-top:18px">
    <h2 style="margin-top:0">When to skip this hub</h2>
    <ul class="muted" style="margin:10px 0 0; padding-left:18px">
      <li>If a service-specific page already matches your real billing question, go there directly.</li>
      <li>If you already have inputs and need a number, start with <a href="/calculators/aws/">AWS calculators</a>.</li>
      <li>If the real issue is not provider-specific yet, start from <a href="/guides/">all guides</a> or a general category page.</li>
    </ul>
  </section>
</BaseLayout>

<style>
  .guide-cluster-grid {
    display: grid;
    gap: 14px;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
  }

  .guide-cluster-card {
    display: flex;
    flex-direction: column;
    min-height: 100%;
  }

  .guide-cluster-copy {
    flex: 1 1 auto;
  }

  .guide-cluster-actions {
    align-items: flex-start;
    gap: 10px;
    margin-top: auto;
    flex-wrap: wrap;
  }

  .guide-cluster-actions .btn {
    white-space: nowrap;
  }

  @media (max-width: 720px) {
    .guide-cluster-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
